    <style>
        *{margin:0;padding:0;box-sizing:border-box}
        :root{--primary:#5b3b8c;--accent:#d4af37;--bg:#0d0e12;--card:#1e2128;--text:#eef0f4;--muted:#8e95a5;--radius:20px}
        body{font-family:'Inter',sans-serif;background:var(--bg);color:var(--text);min-height:100vh}
        .header{display:flex;justify-content:space-between;align-items:center;padding:16px 32px;background:rgba(13,14,18,0.85);backdrop-filter:blur(12px);border-bottom:1px solid rgba(212,175,55,0.12);position:sticky;top:0;z-index:50}
        .brand{font-weight:700;font-size:1.4rem;color:#fff;letter-spacing:.5px}
        .brand span{color:var(--accent)}
        .lang-btn{background:transparent;border:1px solid rgba(255,255,255,0.08);color:var(--muted);padding:5px 14px;border-radius:30px;font-weight:600;font-size:.75rem;cursor:pointer;transition:.2s;text-transform:uppercase}
        .lang-btn.active{background:var(--primary);border-color:var(--accent);color:#fff}
        .lang-btn:hover{background:var(--primary);color:#fff}
        .lang-switch{display:flex;gap:6px}
        .page-container{max-width:1100px;margin:0 auto;padding:20px}
        .page-header{background:#1e2128;padding:30px 40px;border-radius:20px;margin-bottom:30px;border-left:5px solid var(--accent)}
        .page-header h1{color:#d4af37;font-size:2.5rem;display:flex;align-items:center;gap:15px}
        .page-header h1 i{color:var(--accent)}
        .page-header p{color:#b0b8c5;margin-top:10px;font-size:1.05rem;line-height:1.7}
        .section-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:16px;margin-bottom:30px}
        .section-card{background:#1e2128;padding:20px;border-radius:16px;border:1px solid rgba(212,175,55,0.08);transition:.3s;cursor:pointer;text-decoration:none;color:inherit;display:block}
        .section-card:hover{background:#282d38;transform:translateY(-3px);border-color:var(--accent)}
        .section-card i{font-size:2rem;color:var(--accent);margin-bottom:10px;display:block}
        .section-card h3{font-weight:600;font-size:1.1rem;margin-bottom:4px;color:#fff}
        .section-card p{color:var(--muted);font-size:.85rem;line-height:1.5}
        .section-card .badge{display:inline-block;background:rgba(212,175,55,0.12);color:var(--accent);font-size:.65rem;padding:2px 12px;border-radius:20px;margin-top:8px}
        .back-link{margin-top:30px;text-align:center}
        .back-link a{color:#d4af37;text-decoration:none;font-weight:600;font-size:1.05rem;display:inline-flex;align-items:center;gap:10px;transition:.3s}
        .back-link a:hover{transform:translateX(-5px)}
        .lang-persian{direction:rtl}
        .lang-persian .page-header h1{justify-content:flex-end}
        .lang-persian .back-link a{flex-direction:row-reverse}
        @media(max-width:768px){.page-header h1{font-size:1.8rem}.section-grid{grid-template-columns:1fr}}
    </style>
</head>
