<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Karatech ELV · Electrical</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
        *{margin:0;padding:0;box-sizing:border-box}
        body{background:#0d0e12;color:#eef0f4;font-family:sans-serif;padding:40px 20px}
        .page{max-width:1100px;margin:0 auto}
        .header{display:flex;justify-content:space-between;align-items:center;padding:16px 32px;background:#1e2128;border-radius:12px;margin-bottom:30px}
        .brand{font-weight:700;font-size:1.4rem;color:#fff}
        .brand span{color:#d4af37}
        .lang-btn{background:transparent;border:1px solid #333;color:#8e95a5;padding:5px 14px;border-radius:30px;cursor:pointer}
        .lang-btn.active{background:#5b3b8c;border-color:#d4af37;color:#fff}
        .lang-switch{display:flex;gap:6px}
        h1{color:#d4af37;font-size:2.5rem;display:flex;align-items:center;gap:15px}
        h1 i{color:#d4af37}
        .sub{color:#8e95a5;margin:10px 0 30px;font-size:1.05rem}
        .grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:16px;margin-bottom:30px}
        .card{background:#1e2128;padding:20px;border-radius:16px;border:1px solid rgba(212,175,55,0.08);transition:.3s;cursor:pointer;text-decoration:none;color:inherit;display:block}
        .card:hover{background:#282d38;transform:translateY(-3px);border-color:#d4af37}
        .card i{font-size:2rem;color:#d4af37;margin-bottom:10px;display:block}
        .card h3{font-weight:600;font-size:1.1rem;margin-bottom:4px;color:#fff}
        .card p{color:#8e95a5;font-size:.85rem;line-height:1.5}
        .badge{display:inline-block;background:rgba(212,175,55,0.12);color:#d4af37;font-size:.65rem;padding:2px 12px;border-radius:20px;margin-top:8px}
        .back{text-align:center;margin-top:30px}
        .back a{color:#d4af37;text-decoration:none;font-weight:600;font-size:1.05rem}
        .back a:hover{text-decoration:underline}
    </style>
</head>
<body>
<div class="page">

    <div class="header">
        <div class="brand">KARATECH <span>ELV</span></div>
        <div class="lang-switch">
            <button class="lang-btn active" data-lang="en">EN</button>
            <button class="lang-btn" data-lang="fa">FA</button>
        </div>
    </div>

    <h1><i class="fas fa-bolt"></i> Electrical Engineering</h1>
    <div class="sub">Power systems, protection coordination, load calculation. Essential for all industrial and commercial projects.</div>

    <div class="grid">
        <a href="overview.html" class="card">
            <i class="fas fa-graduation-cap"></i>
            <h3>Overview</h3>
            <p>Complete overview of electrical engineering</p>
            <span class="badge">Learn More →</span>
        </a>
        <a href="voltage-drop.html" class="card">
            <i class="fas fa-bolt"></i>
            <h3>Voltage Drop</h3>
            <p>Calculate voltage drop in circuits</p>
            <span class="badge">Calculator →</span>
        </a>
        <a href="power-factor.html" class="card">
            <i class="fas fa-chart-line"></i>
            <h3>Power Factor</h3>
            <p>Calculate power factor and reactive power</p>
            <span class="badge">Calculator →</span>
        </a>
        <a href="transformer-sizing.html" class="card">
            <i class="fas fa-bolt"></i>
            <h3>Transformer Sizing</h3>
            <p>Size transformers for your application</p>
            <span class="badge">Calculator →</span>
        </a>
        <a href="cable-sizing.html" class="card">
            <i class="fas fa-ruler"></i>
            <h3>Cable Sizing</h3>
            <p>Select the right cable size</p>
            <span class="badge">Calculator →</span>
        </a>
        <a href="earthing-resistance.html" class="card">
            <i class="fas fa-bolt"></i>
            <h3>Earthing Resistance</h3>
            <p>Calculate earth resistance</p>
            <span class="badge">Calculator →</span>
        </a>
        <a href="key-topics.html" class="card">
            <i class="fas fa-lightbulb"></i>
            <h3>Key Topics</h3>
            <p>Important topics in electrical engineering</p>
            <span class="badge">Learn More →</span>
        </a>
        <a href="software.html" class="card">
            <i class="fas fa-tools"></i>
            <h3>Software</h3>
            <p>Essential software for electrical engineering</p>
            <span class="badge">Learn More →</span>
        </a>
        <a href="resources.html" class="card">
            <i class="fas fa-book"></i>
            <h3>Resources</h3>
            <p>Standards, handbooks and more</p>
            <span class="badge">Learn More →</span>
        </a>
        <a href="learning-path.html" class="card">
            <i class="fas fa-road"></i>
            <h3>Learning Path</h3>
            <p>From foundation to advanced</p>
            <span class="badge">Learn More →</span>
        </a>
        <a href="videos-future.html" class="card">
            <i class="fas fa-play-circle"></i>
            <h3>Videos & Future</h3>
            <p>Tutorials and future technologies</p>
            <span class="badge">Learn More →</span>
        </a>
        <a href="power-system-analysis.html" class="card">
            <i class="fas fa-chart-line"></i>
            <h3>Power System Analysis</h3>
            <p>Load flow, short-circuit, stability and more</p>
            <span class="badge">Learn More →</span>
        </a>
        <a href="protection-coordination.html" class="card">
            <i class="fas fa-shield-alt"></i>
            <h3>Protection Coordination</h3>
            <p>Protective devices and coordination</p>
            <span class="badge">Learn More →</span>
        </a>
    </div>

    <div class="back">
        <a href="../../index.html" onclick="localStorage.setItem('dashboardActive', 'true')"><i class="fas fa-arrow-left"></i> Back to Dashboard</a>
    </div>

</div>
<script>
    document.querySelectorAll('.lang-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
            document.querySelectorAll('.lang-btn').forEach(function(b) { b.classList.remove('active'); });
            this.classList.add('active');
        });
    });
</script>
</body>
</html>
